---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
---

<Layout title="ER Diagram">
  <div class="page-header">
    <h1>ER Diagram</h1>
    <p class="page-description">Entity-Relationship diagram from the domain model</p>
  </div>

  <div class="section" x-data="erDiagram()" x-on:keydown.escape.window="closePanel()">
    <!-- Error banner (API unreachable) -->
    <template x-if="error">
      <div class="card" style="background: var(--color-warning-bg, #332b00); border-color: var(--color-warning, #f5a623); margin-bottom: var(--space-4);">
        <div class="empty-state">
          <div class="empty-state-icon">⚠️</div>
          <p>
            <strong>Connect to Bropilot server</strong><br />
            <span x-text="error"></span>
          </p>
        </div>
      </div>
    </template>

    <!-- Loading state -->
    <template x-if="loading && !error">
      <div class="card">
        <div class="empty-state">
          <div class="empty-state-icon">⏳</div>
          <p>Loading domain data…</p>
        </div>
      </div>
    </template>

    <!-- Empty state -->
    <template x-if="!loading && !error && isEmpty">
      <div class="card">
        <div class="empty-state">
          <div class="empty-state-icon">📐</div>
          <p>No domain model yet. Run Act 2 domain modeling to extract entities and relationships.</p>
        </div>
      </div>
    </template>

    <!-- Diagram + Entity Explorer layout -->
    <template x-if="!loading && !error && !isEmpty">
      <div class="er-layout">
        <!-- Diagram container -->
        <div class="er-wrapper" x-bind:class="{ 'er-with-panel': selectedEntity }">
          <div class="er-toolbar">
            <span class="er-count" x-text="entityCount + ' entities, ' + relationshipCount + ' relationships'"></span>
            <div class="er-toolbar-actions">
              <span class="er-hint" x-show="!selectedEntity">Click an entity to explore</span>
              <button class="btn btn-sm" x-on:click="refreshDiagram()">↻ Refresh</button>
            </div>
          </div>
          <div class="er-container" id="er-diagram-container">
            <div id="er-mermaid-output"></div>
          </div>
        </div>

        <!-- Entity Explorer Panel (overlay on click-outside backdrop) -->
        <template x-if="selectedEntity">
          <div class="entity-panel-backdrop" x-on:click.self="closePanel()">
            <div class="entity-panel" x-on:click.stop>
              <!-- Panel header -->
              <div class="entity-panel-header">
                <div class="entity-panel-title-row">
                  <span class="entity-panel-icon">📦</span>
                  <h2 class="entity-panel-name" x-text="selectedEntity.name"></h2>
                </div>
                <button class="entity-panel-close" x-on:click="closePanel()" aria-label="Close panel">✕</button>
              </div>

              <!-- Entity description -->
              <template x-if="selectedEntity.description">
                <div class="entity-panel-section">
                  <p class="entity-description" x-text="selectedEntity.description"></p>
                </div>
              </template>

              <!-- Attributes section -->
              <div class="entity-panel-section">
                <h3 class="entity-section-title">Attributes</h3>
                <template x-if="getEntityAttributes(selectedEntity).length === 0">
                  <p class="entity-empty-note">No attributes defined</p>
                </template>
                <template x-if="getEntityAttributes(selectedEntity).length > 0">
                  <div class="entity-attr-list">
                    <template x-for="attr in getEntityAttributes(selectedEntity)" x-bind:key="attr.name">
                      <div class="entity-attr-row">
                        <span class="entity-attr-name" x-text="attr.name"></span>
                        <span class="entity-attr-type" x-text="attr.type"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>

              <!-- Relationships section -->
              <div class="entity-panel-section">
                <h3 class="entity-section-title">Relationships</h3>
                <template x-if="getEntityRelationships(selectedEntity.name).length === 0">
                  <p class="entity-empty-note">No relationships</p>
                </template>
                <template x-if="getEntityRelationships(selectedEntity.name).length > 0">
                  <div class="entity-rel-list">
                    <template x-for="(rel, idx) in getEntityRelationships(selectedEntity.name)" x-bind:key="idx">
                      <div class="entity-rel-row" x-on:click="selectEntityByName(rel.target)">
                        <span class="entity-rel-direction" x-text="rel.direction === 'outgoing' ? '→' : '←'"></span>
                        <span class="entity-rel-type-badge" x-text="rel.type"></span>
                        <span class="entity-rel-target" x-text="rel.target"></span>
                        <template x-if="rel.description">
                          <span class="entity-rel-desc" x-text="rel.description"></span>
                        </template>
                      </div>
                    </template>
                  </div>
                </template>
              </div>

              <!-- Constraints section -->
              <div class="entity-panel-section">
                <h3 class="entity-section-title">Constraints</h3>
                <template x-if="getEntityConstraints(selectedEntity.name).length === 0">
                  <p class="entity-empty-note">No constraints defined</p>
                </template>
                <template x-if="getEntityConstraints(selectedEntity.name).length > 0">
                  <div class="entity-constraint-list">
                    <template x-for="(c, idx) in getEntityConstraints(selectedEntity.name)" x-bind:key="idx">
                      <div class="entity-constraint-row">
                        <div class="entity-constraint-header">
                          <span class="entity-constraint-name" x-text="c.name"></span>
                          <span class="entity-constraint-severity" x-bind:class="'severity-' + c.severity" x-text="c.severity"></span>
                        </div>
                        <p class="entity-constraint-rule" x-text="c.rule"></p>
                        <span class="entity-constraint-enforcement" x-text="'Enforcement: ' + c.enforcement"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>

              <!-- Traceability section -->
              <div class="entity-panel-section">
                <h3 class="entity-section-title">Traceability</h3>
                <template x-if="getEntityTraceability(selectedEntity.name).length === 0">
                  <p class="entity-empty-note">No code linked yet</p>
                </template>
                <template x-if="getEntityTraceability(selectedEntity.name).length > 0">
                  <div class="entity-trace-list">
                    <template x-for="(link, idx) in getEntityTraceability(selectedEntity.name)" x-bind:key="idx">
                      <div class="entity-trace-row">
                        <span class="entity-trace-type" x-bind:class="'trace-badge-' + link.type" x-text="link.type"></span>
                        <span class="entity-trace-path" x-text="link.file_path"></span>
                        <template x-if="link.function_name">
                          <code class="entity-trace-fn" x-text="link.function_name"></code>
                        </template>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
            </div>
          </div>
        </template>
      </div>
    </template>
  </div>
</Layout>

<style>
  .er-layout {
    position: relative;
  }

  .er-wrapper {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    overflow: hidden;
    transition: opacity 0.2s;
  }

  .er-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-tertiary);
  }

  .er-toolbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .er-hint {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .er-count {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .btn-sm {
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-weight: 500;
  }

  .btn-sm:hover {
    background: var(--color-accent-light);
  }

  .er-container {
    padding: var(--space-4);
    overflow: auto;
    max-height: 80vh;
    min-height: 300px;
  }

  /* Ensure Mermaid SVG is scrollable/scalable */
  .er-container :global(svg) {
    max-width: 100%;
    height: auto;
  }

  /* Make entity boxes in the diagram look clickable */
  .er-container :global(.er.entityBox) {
    cursor: pointer;
    transition: stroke-width 0.15s, stroke 0.15s;
  }

  .er-container :global(.er.entityBox:hover) {
    stroke-width: 3;
    stroke: #6366f1;
  }

  .er-container :global(.er.entityLabel) {
    cursor: pointer;
  }

  /* Entity Explorer Panel — slide-over overlay */
  .entity-panel-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 150;
    display: flex;
    justify-content: flex-end;
  }

  .entity-panel {
    width: 420px;
    max-width: 90vw;
    height: 100vh;
    background: var(--color-bg);
    border-left: 1px solid var(--color-border);
    overflow-y: auto;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.15);
    animation: slideIn 0.2s ease-out;
  }

  @keyframes slideIn {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }

  .entity-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) var(--space-5) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .entity-panel-title-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .entity-panel-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .entity-panel-name {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .entity-panel-close {
    background: none;
    border: none;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition: all 0.15s;
  }

  .entity-panel-close:hover {
    color: var(--color-text);
    background: var(--color-bg-tertiary);
  }

  .entity-panel-section {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .entity-panel-section:last-child {
    border-bottom: none;
  }

  .entity-description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .entity-section-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-3) 0;
  }

  .entity-empty-note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  /* Attributes */
  .entity-attr-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .entity-attr-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
  }

  .entity-attr-name {
    font-weight: 500;
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .entity-attr-type {
    font-size: var(--text-xs);
    color: var(--color-accent);
    background: var(--color-accent-bg, rgba(99, 102, 241, 0.1));
    padding: 1px 8px;
    border-radius: 9999px;
    font-family: var(--font-mono);
  }

  /* Relationships */
  .entity-rel-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .entity-rel-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: background 0.1s;
    flex-wrap: wrap;
  }

  .entity-rel-row:hover {
    background: var(--color-bg-tertiary);
  }

  .entity-rel-direction {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .entity-rel-type-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 9999px;
    background: #dbeafe;
    color: #1d4ed8;
    flex-shrink: 0;
  }

  @media (prefers-color-scheme: dark) {
    .entity-rel-type-badge {
      background: #1e3a5f;
      color: #93c5fd;
    }
  }

  .entity-rel-target {
    font-weight: 600;
    color: var(--color-accent);
  }

  .entity-rel-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    width: 100%;
    padding-left: calc(var(--space-2) + 1.2em);
  }

  /* Constraints */
  .entity-constraint-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .entity-constraint-row {
    padding: var(--space-3);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-warning, #f5a623);
  }

  .entity-constraint-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-1);
  }

  .entity-constraint-name {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .entity-constraint-severity {
    font-size: var(--text-xs);
    padding: 1px 6px;
    border-radius: 9999px;
    font-weight: 600;
  }

  .severity-hard {
    background: #fee2e2;
    color: #b91c1c;
  }

  .severity-soft {
    background: #fef3c7;
    color: #92400e;
  }

  @media (prefers-color-scheme: dark) {
    .severity-hard {
      background: #450a0a;
      color: #fca5a5;
    }
    .severity-soft {
      background: #451a03;
      color: #fcd34d;
    }
  }

  .entity-constraint-rule {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-1) 0;
    line-height: 1.5;
  }

  .entity-constraint-enforcement {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Traceability */
  .entity-trace-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .entity-trace-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    flex-wrap: wrap;
  }

  .entity-trace-type {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .trace-badge-implementation {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .trace-badge-test {
    background: #dcfce7;
    color: #15803d;
  }

  .trace-badge-type {
    background: #fef3c7;
    color: #92400e;
  }

  .trace-badge-migration {
    background: #f3e8ff;
    color: #7c3aed;
  }

  @media (prefers-color-scheme: dark) {
    .trace-badge-implementation {
      background: #1e3a5f;
      color: #93c5fd;
    }
    .trace-badge-test {
      background: #14532d;
      color: #86efac;
    }
    .trace-badge-type {
      background: #451a03;
      color: #fcd34d;
    }
    .trace-badge-migration {
      background: #3b0764;
      color: #c4b5fd;
    }
  }

  .entity-trace-path {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    word-break: break-all;
  }

  .entity-trace-fn {
    font-size: var(--text-xs);
    color: var(--color-accent);
    background: var(--color-accent-bg, rgba(99, 102, 241, 0.1));
    padding: 1px 4px;
    border-radius: var(--radius-sm);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .entity-panel {
      width: 100vw;
      max-width: 100vw;
    }

    .er-hint {
      display: none;
    }
  }

  [x-cloak] {
    display: none !important;
  }
</style>

<script>
  import { getClientApiConfig, type ApiError } from '../lib/api';

  interface Entity {
    name: string;
    description?: string;
    attributes?: Record<string, string> | Array<{ name: string; type: string }>;
    relationships?: Array<{ target: string; type: string; description?: string }>;
  }

  interface Relationship {
    source: string;
    target: string;
    type: string;
    description?: string;
  }

  interface Constraint {
    name: string;
    rule: string;
    severity: string;
    enforcement: string;
    applies_to: string[];
  }

  interface TraceabilityLink {
    type: string;
    file_path: string;
    function_name?: string;
    line_range?: [number, number];
  }

  interface TraceabilityEntry {
    spec_category: string;
    spec_id: string;
    links: TraceabilityLink[];
  }

  interface EntityRelationship {
    direction: 'outgoing' | 'incoming';
    type: string;
    target: string;
    description?: string;
  }

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

  document.addEventListener('alpine:init', () => {
    window.Alpine.data('erDiagram', () => ({
      loading: true,
      error: '',
      isEmpty: false,
      entities: [] as Entity[],
      relationships: [] as Relationship[],
      constraints: [] as Constraint[],
      traceabilityEntries: [] as TraceabilityEntry[],
      entityCount: 0,
      relationshipCount: 0,
      selectedEntity: null as Entity | null,

      async init() {
        await this.loadData();
      },

      async loadData() {
        this.loading = true;
        this.error = '';
        this.isEmpty = false;

        try {
          const cfg = getClientApiConfig(API_URL);
          const headers: Record<string, string> = { 'Content-Type': 'application/json' };
          if (cfg.token) headers['Authorization'] = `Bearer ${cfg.token}`;

          // Fetch domain data, constraints, and traceability in parallel
          const [domainRes, specsRes, traceRes] = await Promise.all([
            fetch(`${cfg.url}/api/map/solution/domain`, { headers }),
            fetch(`${cfg.url}/api/map/solution/specs`, { headers }).catch(() => null),
            fetch(`${cfg.url}/api/traceability`, { headers }).catch(() => null),
          ]);

          // Process domain data
          if (!domainRes.ok) {
            if (domainRes.status === 404) {
              this.isEmpty = true;
              this.loading = false;
              return;
            }
            throw new Error(`Server responded ${domainRes.status}`);
          }

          const json = await domainRes.json();
          if (!json.ok) {
            if (json.error?.includes('not found')) {
              this.isEmpty = true;
              this.loading = false;
              return;
            }
            throw new Error(json.error || 'Unknown error');
          }

          const data = json.data || {};
          const entitiesData = data.entities?.entities || data.entities || [];
          const relationshipsData = data.relationships?.relationships || data.relationships || [];

          this.entities = Array.isArray(entitiesData) ? entitiesData : [];
          this.relationships = Array.isArray(relationshipsData) ? relationshipsData : [];
          this.entityCount = this.entities.length;
          this.relationshipCount = this.relationships.length;

          // Process constraints from specs
          if (specsRes && specsRes.ok) {
            try {
              const specsJson = await specsRes.json();
              if (specsJson.ok && specsJson.data) {
                const constraintsData = specsJson.data.constraints;
                if (constraintsData) {
                  const rawConstraints = constraintsData.constraints || constraintsData;
                  this.constraints = Array.isArray(rawConstraints) ? rawConstraints : [];
                }
              }
            } catch { /* constraints not available — that's fine */ }
          }

          // Process traceability data
          if (traceRes && traceRes.ok) {
            try {
              const traceJson = await traceRes.json();
              if (traceJson.ok && traceJson.data) {
                this.traceabilityEntries = traceJson.data.entries || [];
              }
            } catch { /* traceability not available — that's fine */ }
          }

          if (this.entities.length === 0) {
            this.isEmpty = true;
            this.loading = false;
            return;
          }

          this.loading = false;

          // Wait for Alpine to render the DOM, then render diagram
          await this.$nextTick();
          await this.renderDiagram();
        } catch (err: unknown) {
          const error = err as Error;
          if (error.message?.includes('Failed to fetch') || error.message?.includes('NetworkError')) {
            this.error = 'Could not reach the API. Make sure the Bropilot Elixir backend is running.';
          } else {
            this.error = error.message || 'Failed to load domain data';
          }
          this.loading = false;
        }
      },

      async refreshDiagram() {
        this.selectedEntity = null;
        await this.loadData();
      },

      /** Select an entity by name (used for clicking relationships to navigate) */
      selectEntityByName(name: string) {
        const entity = this.entities.find(
          (e: Entity) => e.name === name || sanitizeName(e.name) === sanitizeName(name),
        );
        if (entity) {
          this.selectedEntity = entity;
        }
      },

      /** Close the entity explorer panel */
      closePanel() {
        this.selectedEntity = null;
      },

      /** Get normalized attributes for an entity */
      getEntityAttributes(entity: Entity): Array<{ name: string; type: string }> {
        return normalizeAttributes(entity.attributes);
      },

      /** Get both incoming and outgoing relationships for a given entity */
      getEntityRelationships(entityName: string): EntityRelationship[] {
        const results: EntityRelationship[] = [];
        const safeName = entityName;

        // Outgoing from global relationships
        for (const rel of this.relationships) {
          if (rel.source === safeName) {
            results.push({
              direction: 'outgoing',
              type: rel.type,
              target: rel.target,
              description: rel.description,
            });
          }
          if (rel.target === safeName && rel.source !== safeName) {
            results.push({
              direction: 'incoming',
              type: rel.type,
              target: rel.source,
              description: rel.description,
            });
          }
        }

        // Also include entity-level relationships (from entity.relationships array)
        const entity = this.entities.find((e: Entity) => e.name === entityName);
        if (entity?.relationships) {
          for (const rel of entity.relationships) {
            // Avoid duplicate with global relationships
            const isDuplicate = results.some(
              (r) => r.target === rel.target && r.type === rel.type && r.direction === 'outgoing',
            );
            if (!isDuplicate) {
              results.push({
                direction: 'outgoing',
                type: rel.type,
                target: rel.target,
                description: rel.description,
              });
            }
          }
        }

        return results;
      },

      /** Get constraints that apply to the given entity */
      getEntityConstraints(entityName: string): Constraint[] {
        return this.constraints.filter((c: Constraint) => {
          if (!c.applies_to) return false;
          return c.applies_to.some(
            (name: string) => name === entityName || name.toLowerCase() === entityName.toLowerCase(),
          );
        });
      },

      /** Get traceability links for the given entity (from entities spec category) */
      getEntityTraceability(entityName: string): TraceabilityLink[] {
        const entry = this.traceabilityEntries.find(
          (e: TraceabilityEntry) =>
            e.spec_category === 'entities' &&
            (e.spec_id === entityName || e.spec_id.toLowerCase() === entityName.toLowerCase()),
        );
        return entry ? entry.links : [];
      },

      buildMermaidDefinition(): string {
        const lines: string[] = ['erDiagram'];

        // Render entities with attributes
        for (const entity of this.entities) {
          const safeName = sanitizeName(entity.name);

          const attrs = normalizeAttributes(entity.attributes);
          if (attrs.length > 0) {
            lines.push(`    ${safeName} {`);
            for (const attr of attrs) {
              const safeType = sanitizeType(attr.type);
              const safeProp = sanitizeName(attr.name);
              lines.push(`        ${safeType} ${safeProp}`);
            }
            lines.push('    }');
          } else {
            // Entity with no attributes — just declare it
            lines.push(`    ${safeName} {`);
            lines.push('    }');
          }
        }

        // Collect entity names for validation
        const entityNames = new Set(this.entities.map((e: Entity) => sanitizeName(e.name)));

        // Render relationships
        for (const rel of this.relationships) {
          const source = sanitizeName(rel.source);
          const target = sanitizeName(rel.target);

          // Only render if both entities exist
          if (!entityNames.has(source) || !entityNames.has(target)) continue;

          const { left, right } = cardinalityMarkers(rel.type);
          const label = rel.description
            ? `"${escapeLabel(rel.description)}"`
            : `"${rel.type}"`;

          lines.push(`    ${source} ${left}--${right} ${target} : ${label}`);
        }

        return lines.join('\n');
      },

      async renderDiagram() {
        const container = document.getElementById('er-mermaid-output');
        if (!container) return;

        const definition = this.buildMermaidDefinition();

        try {
          // Dynamic import of Mermaid to avoid SSR issues
          const { default: mermaid } = await import('mermaid');
          mermaid.initialize({
            startOnLoad: false,
            theme: 'base',
            themeVariables: {
              primaryColor: '#eef2ff',
              primaryBorderColor: '#6366f1',
              primaryTextColor: '#1a1a2e',
              lineColor: '#6366f1',
              secondaryColor: '#f0f0f0',
              tertiaryColor: '#fafafa',
              fontSize: '14px',
            },
            er: {
              useMaxWidth: true,
              layoutDirection: 'TB',
            },
            securityLevel: 'loose',
          });

          // Use unique ID for re-renders
          const id = 'er-diagram-' + Date.now();
          const { svg } = await mermaid.render(id, definition);
          container.innerHTML = svg;

          // Attach click handlers to entity boxes in the SVG
          this.attachEntityClickHandlers(container);
        } catch (renderErr: unknown) {
          const error = renderErr as Error;
          console.error('[er] Mermaid render error:', error);
          container.innerHTML = `
            <div class="empty-state">
              <div class="empty-state-icon">⚠️</div>
              <p>Failed to render diagram. ${escapeHtml(error.message || 'Unknown rendering error')}</p>
            </div>
          `;
        }
      },

      /**
       * Attach click handlers to entity elements in the rendered Mermaid SVG.
       * Mermaid ER diagrams group each entity in <g> elements with entity-related
       * classes. We find these groups and add click listeners.
       */
      attachEntityClickHandlers(container: HTMLElement) {
        const self = this;

        // Build a map of sanitized name → original entity for lookups
        const entityMap = new Map<string, Entity>();
        for (const entity of this.entities) {
          entityMap.set(sanitizeName(entity.name), entity);
          // Also map by original name in case Mermaid uses it
          entityMap.set(entity.name, entity);
        }

        // Mermaid ER diagrams render entities with id patterns like "entity-EntityName"
        // and wrap them in <g> elements. We look for entity boxes within the SVG.
        const svgEl = container.querySelector('svg');
        if (!svgEl) return;

        // Strategy 1: Find <g> elements with ids containing "entity-EntityName"
        // Mermaid uses ids like "er-diagram-TIMESTAMP-entity-User-0"
        const gElements = svgEl.querySelectorAll('g[id]');
        for (const g of gElements) {
          const gId = g.getAttribute('id') || '';
          // Match pattern: ...-entity-EntityName-N
          const entityMatch = gId.match(/-entity-([A-Za-z0-9_]+)-\d+$/);
          if (entityMatch) {
            const entityKey = entityMatch[1];
            const entity = entityMap.get(entityKey);
            if (entity) {
              (g as SVGGElement).style.cursor = 'pointer';
              g.addEventListener('click', (e: Event) => {
                e.stopPropagation();
                self.selectedEntity = entity;
              });
              continue;
            }
          }
        }

        // Strategy 2: Find text elements that match entity names and make their
        // parent <g> clickable. This handles various Mermaid versions.
        const textElements = svgEl.querySelectorAll('text');
        for (const text of textElements) {
          const textContent = (text.textContent || '').trim();
          const entity = entityMap.get(textContent);
          if (entity) {
            // Find the enclosing <g> with a rect (entity box)
            let parentG: Element | null = text.parentElement;
            // Walk up to find a <g> that contains a <rect> (the entity box)
            while (parentG && parentG !== svgEl) {
              const rect = parentG.querySelector('rect');
              if (rect && parentG.tagName === 'g') {
                (parentG as SVGGElement).style.cursor = 'pointer';
                // Avoid adding duplicate listeners
                if (!(parentG as HTMLElement).dataset.entityBound) {
                  (parentG as HTMLElement).dataset.entityBound = 'true';
                  parentG.addEventListener('click', (e: Event) => {
                    e.stopPropagation();
                    self.selectedEntity = entity;
                  });
                }
                break;
              }
              parentG = parentG.parentElement;
            }
          }
        }
      },
    }));
  });

  /**
   * Sanitize entity/attribute name for Mermaid ER syntax.
   * Mermaid ER names must be alphanumeric (with underscores).
   */
  function sanitizeName(name: string): string {
    return name.replace(/[^a-zA-Z0-9_]/g, '_').replace(/^_+|_+$/g, '') || 'unnamed';
  }

  /**
   * Sanitize type name for Mermaid. Replace spaces and special chars.
   */
  function sanitizeType(type: string): string {
    // Mermaid ER attribute types must be single words (no spaces, commas, parens).
    // For enums like "enum(admin, member)", simplify to "enum".
    let t = type;
    // Strip parenthesized content: enum(a, b) → enum
    t = t.replace(/\(.*\)/, '');
    // Replace remaining non-alphanumeric chars with underscore
    t = t.replace(/[^a-zA-Z0-9_]/g, '_').replace(/^_+|_+$/g, '');
    return t || 'string';
  }

  /**
   * Normalize attributes from either Record<string, string> or Array format.
   */
  function normalizeAttributes(
    attrs?: Record<string, string> | Array<{ name: string; type: string }>
  ): Array<{ name: string; type: string }> {
    if (!attrs) return [];

    if (Array.isArray(attrs)) {
      return attrs.map((a) => ({
        name: a.name || 'unknown',
        type: a.type || 'string',
      }));
    }

    // Record<string, string> format: { id: "uuid", name: "string" }
    return Object.entries(attrs).map(([key, val]) => ({
      name: key,
      type: typeof val === 'string' ? val : 'string',
    }));
  }

  /**
   * Map relationship type to Mermaid cardinality markers.
   * Mermaid ER uses: ||--|| (1:1), ||--|{ (1:N), }|--|| (N:1), }|--|{ (N:M)
   */
  function cardinalityMarkers(type: string): { left: string; right: string } {
    switch (type?.toLowerCase()) {
      case 'has_one':
        return { left: '||', right: '||' };
      case 'has_many':
        return { left: '||', right: 'o{' };
      case 'belongs_to':
        return { left: '}o', right: '||' };
      case 'many_to_many':
        return { left: '}o', right: 'o{' };
      case 'produces':
        return { left: '||', right: 'o{' };
      case 'feeds_back':
        return { left: '}o', right: '||' };
      case 'validates_gate':
        return { left: '||', right: '||' };
      default:
        return { left: '||', right: 'o{' };
    }
  }

  /**
   * Escape label text for Mermaid string literals.
   */
  function escapeLabel(text: string): string {
    return text.replace(/"/g, "'").replace(/\n/g, ' ').substring(0, 60);
  }

  /**
   * Basic HTML escaping for error messages.
   */
  function escapeHtml(text: string): string {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }
</script>
