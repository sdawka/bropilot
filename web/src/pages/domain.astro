---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<Layout title="Domain Modeling">
  <div class="page-header">
    <h1>Domain — Solution Exploration</h1>
    <p class="page-description">
      Freeform conversation about the solution space: vocabulary, entities, flows, architecture, specs. Both Vibe and Domain views feed the same exploration session.
    </p>
  </div>

  <div class="section" x-data={`exploreChat('${apiUrl}', 'solution')`}>
    <template x-if="error">
      <div class="card" style="background: var(--color-warning-bg, #332b00); border-color: var(--color-warning, #f5a623); margin-bottom: var(--space-4);">
        <div class="empty-state">
          <div class="empty-state-icon">⚠️</div>
          <p>
            <strong>Connect to Bropilot server</strong><br />
            <span x-text="error"></span>
          </p>
        </div>
      </div>
    </template>

    <template x-if="!started">
      <div class="card">
        <div class="empty-state">
          <div class="empty-state-icon">🌐</div>
          <p>Start an exploration session to capture solution-space context: vocabulary, entities, relationships, user &amp; system flows, architecture, and specs.</p>
          <div style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
            <button class="btn btn-primary" x-on:click="start('mock')" x-bind:disabled="loading">
              <span x-show="!loading">Start (Mock)</span>
              <span x-show="loading">Starting…</span>
            </button>
            <button class="btn btn-secondary" x-on:click="start('llm')" x-bind:disabled="loading">
              Start (LLM)
            </button>
          </div>
        </div>
      </div>
    </template>

    <template x-if="started">
      <div>
        <div class="vibe-chat" id="domain-chat">
          <template x-if="messages.length === 0">
            <div class="chat-message chat-bot">
              <div class="chat-avatar"><span>⬡</span></div>
              <div class="chat-bubble">
                <div class="chat-role">Bropilot</div>
                <div class="chat-text">
                  Session started. Describe the solution: key concepts (vocabulary), main entities and how they relate, user flows, system flows, and architectural choices. Extract when you're ready.
                </div>
              </div>
            </div>
          </template>

          <template x-for="(msg, i) in messages" x-bind:key="i">
            <div class="chat-message" x-bind:class="msg.role === 'bot' ? 'chat-bot' : 'chat-user'">
              <div class="chat-avatar">
                <span x-text="msg.role === 'bot' ? '⬡' : '●'"></span>
              </div>
              <div class="chat-bubble">
                <div class="chat-role" x-text="msg.role === 'bot' ? 'Bropilot' : 'You'"></div>
                <div class="chat-text" x-text="msg.text"></div>
              </div>
            </div>
          </template>

          <template x-if="loading">
            <div class="chat-message chat-bot">
              <div class="chat-avatar"><span>⬡</span></div>
              <div class="chat-bubble">
                <div class="chat-role">Bropilot</div>
                <div class="chat-text typing">Working…</div>
              </div>
            </div>
          </template>
        </div>

        <div class="vibe-input">
          <form x-on:submit.prevent="send()" class="vibe-form">
            <textarea
              class="vibe-textarea"
              placeholder="Describe entities, relationships, user flows, system flows, architecture…"
              x-model="input"
              x-bind:disabled="loading"
              x-ref="vibeInput"
              rows="5"
            ></textarea>
            <div class="vibe-actions">
              <button type="submit" class="btn btn-primary" x-bind:disabled="loading || !input.trim()">
                Send message
              </button>
              <button type="button" class="btn btn-secondary" x-on:click="extract()" x-bind:disabled="loading">
                Extract
              </button>
              <button type="button" class="btn btn-secondary" x-on:click="refreshReadiness()" x-bind:disabled="loading">
                Refresh readiness
              </button>
            </div>
          </form>
        </div>

        <template x-if="readiness">
          <div class="readiness-grid">
            <div class="card readiness-card readiness-focus">
              <div class="card-header"><h3 class="card-title">Solution slots</h3></div>
              <div class="card-body">
                <div class="slot-group">
                  <div class="slot-label slot-filled">Filled</div>
                  <template x-if="(readiness.solution?.filled || []).length === 0">
                    <span class="slot-empty-msg">none yet</span>
                  </template>
                  <template x-for="slot in (readiness.solution?.filled || [])" x-bind:key="'sf-'+slot">
                    <span class="badge badge-completed" x-text="slot"></span>
                  </template>
                </div>
                <div class="slot-group">
                  <div class="slot-label slot-missing">Empty</div>
                  <template x-if="(readiness.solution?.empty || []).length === 0">
                    <span class="slot-empty-msg">all filled ✓</span>
                  </template>
                  <template x-for="slot in (readiness.solution?.empty || [])" x-bind:key="'se-'+slot">
                    <span class="badge badge-pending" x-text="slot"></span>
                  </template>
                </div>
              </div>
            </div>

            <div class="card readiness-card">
              <div class="card-header"><h3 class="card-title">Problem slots</h3></div>
              <div class="card-body">
                <div class="slot-group">
                  <div class="slot-label slot-filled">Filled</div>
                  <template x-if="(readiness.problem?.filled || []).length === 0">
                    <span class="slot-empty-msg">none yet</span>
                  </template>
                  <template x-for="slot in (readiness.problem?.filled || [])" x-bind:key="'pf-'+slot">
                    <span class="badge badge-completed" x-text="slot"></span>
                  </template>
                </div>
                <div class="slot-group">
                  <div class="slot-label slot-missing">Empty</div>
                  <template x-if="(readiness.problem?.empty || []).length === 0">
                    <span class="slot-empty-msg">all filled ✓</span>
                  </template>
                  <template x-for="slot in (readiness.problem?.empty || [])" x-bind:key="'pe-'+slot">
                    <span class="badge badge-pending" x-text="slot"></span>
                  </template>
                </div>
              </div>
            </div>
          </div>
        </template>

        <div class="commit-area" x-show="started">
          <button class="btn btn-primary" x-on:click="commit()" x-bind:disabled="loading">
            Commit to Work
          </button>
          <template x-if="committed">
            <span class="commit-status commit-ok" x-text="'Phase: ' + committed.phase"></span>
          </template>
          <template x-if="commitError">
            <span class="commit-status commit-err" x-text="commitError"></span>
          </template>
        </div>
      </div>
    </template>
  </div>
</Layout>

<script>
  import { clientPost, clientGet } from '../lib/api';

  type Readiness = {
    problem?: { filled?: string[]; empty?: string[] };
    solution?: { filled?: string[]; empty?: string[] };
  };

  document.addEventListener('alpine:init', () => {
    // @ts-ignore
    window.Alpine.data('exploreChat', (apiUrl: string, _focus: string) => ({
      messages: [] as Array<{ role: string; text: string }>,
      input: '',
      loading: false,
      started: false,
      error: '',
      readiness: null as Readiness | null,
      committed: null as { phase: string } | null,
      commitError: '',

      async start(mode: string) {
        this.loading = true;
        this.error = '';
        try {
          const json = await clientPost(apiUrl, '/api/explore/start', { mode }) as { ok: boolean };
          if (json.ok) {
            this.started = true;
            await this.refreshReadiness();
          } else {
            throw new Error('Unexpected response');
          }
        } catch (err: unknown) {
          this.error = `Could not start exploration. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
      },

      async send() {
        const text = this.input.trim();
        if (!text) return;
        this.messages.push({ role: 'user', text });
        this.input = '';
        this.loading = true;
        this.error = '';
        this.scrollToBottom();
        try {
          const json = await clientPost(apiUrl, '/api/explore/message', { text }) as { ok: boolean; data?: { message_count?: number } };
          if (json.ok) {
            this.messages.push({ role: 'bot', text: `Message received (${json.data?.message_count ?? '?'} total). Extract when ready.` });
          }
        } catch (err: unknown) {
          this.error = `Failed to send message. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
        this.scrollToBottom();
        this.$nextTick(() => {
          if (this.$refs.vibeInput) (this.$refs.vibeInput as HTMLTextAreaElement).focus();
        });
      },

      async extract() {
        this.loading = true;
        this.error = '';
        try {
          const json = await clientPost(apiUrl, '/api/explore/extract') as { ok: boolean; data?: { written_slots?: string[] } };
          if (json.ok) {
            const written = json.data?.written_slots || [];
            this.messages.push({ role: 'bot', text: written.length ? `Extracted ${written.length} slot(s): ${written.join(', ')}` : 'Extraction completed — no new slots filled.' });
            await this.refreshReadiness();
          }
        } catch (err: unknown) {
          this.error = `Failed to extract. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
        this.scrollToBottom();
      },

      async refreshReadiness() {
        try {
          const json = await clientGet(apiUrl, '/api/explore/readiness') as { ok: boolean; data?: Readiness };
          if (json.ok && json.data) this.readiness = json.data;
        } catch (err: unknown) {
          // keep prior
        }
      },

      async commit() {
        this.loading = true;
        this.commitError = '';
        try {
          const json = await clientPost(apiUrl, '/api/explore/commit') as { ok: boolean; error?: string; data?: { phase?: string } };
          if (json.ok && json.data?.phase) {
            this.committed = { phase: json.data.phase };
          } else {
            this.commitError = json.error || 'Commit failed';
            await this.refreshReadiness();
          }
        } catch (err: unknown) {
          this.commitError = `Commit failed. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
      },

      scrollToBottom() {
        this.$nextTick(() => {
          const chat = document.getElementById('domain-chat');
          if (chat) chat.scrollTop = chat.scrollHeight;
        });
      },
    }));
  });
</script>

<style>
  .vibe-chat {
    max-height: 50vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .chat-message { display: flex; gap: var(--space-3); align-items: flex-start; }
  .chat-user { flex-direction: row-reverse; }

  .chat-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--color-bg-tertiary);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: var(--text-base);
  }
  .chat-bot .chat-avatar { background: rgba(99, 102, 241, 0.15); color: var(--color-accent); }
  .chat-user .chat-avatar { background: rgba(34, 197, 94, 0.15); color: var(--color-success, #22c55e); }

  .chat-bubble {
    max-width: 70%;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }
  .chat-user .chat-bubble { background: rgba(99, 102, 241, 0.08); border-color: rgba(99, 102, 241, 0.2); }

  .chat-role {
    font-size: var(--text-xs); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--color-text-muted); margin-bottom: var(--space-1);
  }
  .chat-text { font-size: var(--text-sm); line-height: 1.6; color: var(--color-text-secondary); white-space: pre-wrap; }
  .chat-text.typing { color: var(--color-text-muted); font-style: italic; }

  .vibe-input { padding-top: var(--space-4); border-top: 1px solid var(--color-border); }
  .vibe-form { display: flex; flex-direction: column; gap: var(--space-3); }
  .vibe-textarea {
    width: 100%;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3);
    color: var(--color-text-primary);
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    resize: vertical;
  }
  .vibe-actions { display: flex; gap: var(--space-2); flex-wrap: wrap; }

  .readiness-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);
    margin-top: var(--space-4);
  }
  @media (max-width: 720px) { .readiness-grid { grid-template-columns: 1fr; } }
  .readiness-focus { border-color: var(--color-accent); }
  .slot-group { display: flex; flex-wrap: wrap; gap: var(--space-2); align-items: center; margin-bottom: var(--space-3); }
  .slot-label { font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-right: var(--space-2); }
  .slot-filled { color: var(--color-success, #22c55e); }
  .slot-missing { color: var(--color-warning, #f5a623); }
  .slot-empty-msg { font-size: var(--text-xs); color: var(--color-text-muted); font-style: italic; }

  .commit-area { margin-top: var(--space-4); padding-top: var(--space-4); border-top: 1px solid var(--color-border); display: flex; gap: var(--space-3); align-items: center; flex-wrap: wrap; }
  .commit-status { font-size: var(--text-sm); }
  .commit-ok { color: var(--color-success, #22c55e); }
  .commit-err { color: var(--color-warning, #f5a623); }

  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm); font-weight: 600;
    border: 1px solid transparent; border-radius: var(--radius-sm);
    cursor: pointer; transition: all 0.15s ease; white-space: nowrap;
  }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-primary { background: var(--color-accent); color: white; border-color: var(--color-accent); }
  .btn-primary:hover:not(:disabled) { filter: brightness(1.1); }
  .btn-secondary { background: transparent; color: var(--color-text-secondary); border-color: var(--color-border); }
  .btn-secondary:hover:not(:disabled) { background: var(--color-bg-secondary); }
</style>
</content>
</invoke>