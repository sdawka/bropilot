---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { SPEC_CATEGORIES, formatSpecName } from '../lib/api';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

const specNames = SPEC_CATEGORIES.map((cat) => ({
  id: cat,
  label: formatSpecName(cat),
}));
---

<Layout title="Domain Modeling">
  <div class="page-header">
    <h1>Domain Modeling</h1>
    <p class="page-description">Act 2 — Define the big picture domain model and expand into detailed specs</p>
  </div>

  <div class="section" x-data={`domainChat('${apiUrl}')`}>
    <!-- Error banner -->
    <template x-if="error">
      <div class="card" style="background: var(--color-warning-bg, #332b00); border-color: var(--color-warning, #f5a623); margin-bottom: var(--space-4);">
        <div class="empty-state">
          <div class="empty-state-icon">⚠️</div>
          <p>
            <strong>Connect to Bropilot server</strong><br />
            <span x-text="error"></span>
          </p>
        </div>
      </div>
    </template>

    <!-- Chat messages -->
    <div class="domain-chat" id="domain-chat">
      <!-- Idle state: Start button -->
      <template x-if="phase === 'idle'">
        <div class="card">
          <div class="empty-state">
            <div class="empty-state-icon">🌐</div>
            <p>Start domain modeling to define your app's vocabulary, entities, relationships, flows, and architecture.</p>
            <button class="btn btn-primary" x-on:click="start()" x-bind:disabled="loading">
              <span x-show="!loading">Start Domain Modeling</span>
              <span x-show="loading">Starting…</span>
            </button>
          </div>
        </div>
      </template>

      <!-- Chat history -->
      <template x-for="(msg, i) in messages" x-bind:key="i">
        <div class="chat-message" x-bind:class="msg.role === 'bot' ? 'chat-bot' : 'chat-user'">
          <div class="chat-avatar">
            <span x-text="msg.role === 'bot' ? '⬡' : '●'"></span>
          </div>
          <div class="chat-bubble">
            <div class="chat-role" x-text="msg.role === 'bot' ? 'Bropilot' : 'You'"></div>
            <div class="chat-text" x-html="msg.html ? msg.text : undefined" x-text="msg.html ? undefined : msg.text"></div>
          </div>
        </div>
      </template>

      <!-- Loading indicator -->
      <template x-if="loading && phase !== 'idle'">
        <div class="chat-message chat-bot">
          <div class="chat-avatar"><span>⬡</span></div>
          <div class="chat-bubble">
            <div class="chat-role">Bropilot</div>
            <div class="chat-text typing" x-text="loadingMessage"></div>
          </div>
        </div>
      </template>
    </div>

    <!-- Input area for Step 3 -->
    <template x-if="phase === 'step3' && !loading">
      <div class="domain-input">
        <form x-on:submit.prevent="submitInput()" class="domain-form">
          <textarea
            class="domain-textarea"
            placeholder="Describe your domain… What does your application do? What are the main concepts?"
            x-model="input"
            x-bind:disabled="loading"
            x-ref="domainInput"
            rows="4"
          ></textarea>
          <button type="submit" class="btn btn-primary" x-bind:disabled="loading || !input.trim()">
            Submit &amp; Extract
          </button>
        </form>
      </div>
    </template>

    <!-- Domain model cards (Step 3 done) -->
    <template x-if="step3Data && (phase === 'step3_done' || phase === 'step4' || phase === 'extracting4' || phase === 'complete')">
      <div class="domain-results">
        <h2 class="section-title">Domain Model</h2>
        <div class="card-grid">
          <!-- Vocabulary -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">📖 Vocabulary</h3>
              <span class="badge badge-completed" x-text="(step3Data.vocabulary || []).length + ' terms'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.vocabulary && step3Data.vocabulary.length > 0">
                <div class="domain-list">
                  <template x-for="(item, vi) in step3Data.vocabulary" x-bind:key="vi">
                    <div class="domain-list-item">
                      <strong x-text="item.term"></strong>
                      <span class="domain-meta" x-text="item.category ? `[${item.category}]` : ''"></span>
                      <p x-text="item.definition"></p>
                      <template x-if="item.aliases && item.aliases.length">
                        <div class="domain-aliases">
                          <span class="domain-label">Aliases:</span>
                          <template x-for="(alias, ai) in item.aliases" x-bind:key="ai">
                            <span class="badge badge-pending" x-text="alias"></span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.vocabulary || step3Data.vocabulary.length === 0">
                <div class="empty-state"><p>No vocabulary extracted</p></div>
              </template>
            </div>
          </div>

          <!-- Entities -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">📦 Entities</h3>
              <span class="badge badge-completed" x-text="(step3Data.entities || []).length + ' entities'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.entities && step3Data.entities.length > 0">
                <div class="domain-list">
                  <template x-for="(ent, ei) in step3Data.entities" x-bind:key="ei">
                    <div class="domain-list-item">
                      <strong x-text="ent.name"></strong>
                      <p x-text="ent.description"></p>
                      <template x-if="ent.attributes">
                        <div class="domain-attrs">
                          <span class="domain-label">Attributes:</span>
                          <template x-for="(val, key) in ent.attributes" x-bind:key="key">
                            <span class="badge badge-pending"><span x-text="key"></span>: <span x-text="val"></span></span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.entities || step3Data.entities.length === 0">
                <div class="empty-state"><p>No entities extracted</p></div>
              </template>
            </div>
          </div>

          <!-- Relationships -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">🔗 Relationships</h3>
              <span class="badge badge-completed" x-text="(step3Data.relationships || []).length + ' relationships'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.relationships && step3Data.relationships.length > 0">
                <div class="domain-list">
                  <template x-for="(rel, ri) in step3Data.relationships" x-bind:key="ri">
                    <div class="domain-list-item">
                      <strong>
                        <span x-text="rel.source"></span>
                        <span class="domain-arrow">→</span>
                        <span x-text="rel.target"></span>
                      </strong>
                      <span class="badge badge-in-progress" x-text="rel.type"></span>
                      <p x-text="rel.description"></p>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.relationships || step3Data.relationships.length === 0">
                <div class="empty-state"><p>No relationships extracted</p></div>
              </template>
            </div>
          </div>

          <!-- User Flows -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">🔄 Flows</h3>
              <span class="badge badge-completed" x-text="((step3Data.user_flows || []).length + (step3Data.system_flows || []).length) + ' flows'"></span>
            </div>
            <div class="card-body">
              <template x-if="(step3Data.user_flows && step3Data.user_flows.length > 0) || (step3Data.system_flows && step3Data.system_flows.length > 0)">
                <div class="domain-list">
                  <template x-if="step3Data.user_flows && step3Data.user_flows.length > 0">
                    <div>
                      <div class="domain-subheading">User Flows</div>
                      <template x-for="(flow, fi) in step3Data.user_flows" x-bind:key="'uf-'+fi">
                        <div class="domain-list-item">
                          <strong x-text="flow.name"></strong>
                          <span class="domain-meta" x-text="flow.actor ? `Actor: ${flow.actor}` : ''"></span>
                          <p x-text="flow.trigger"></p>
                          <template x-if="flow.steps && flow.steps.length">
                            <ol class="domain-steps">
                              <template x-for="(s, si) in flow.steps" x-bind:key="si">
                                <li x-text="s"></li>
                              </template>
                            </ol>
                          </template>
                          <div class="domain-meta" x-text="flow.outcome ? `Outcome: ${flow.outcome}` : ''"></div>
                        </div>
                      </template>
                    </div>
                  </template>
                  <template x-if="step3Data.system_flows && step3Data.system_flows.length > 0">
                    <div>
                      <div class="domain-subheading">System Flows</div>
                      <template x-for="(flow, fi) in step3Data.system_flows" x-bind:key="'sf-'+fi">
                        <div class="domain-list-item">
                          <strong x-text="flow.name"></strong>
                          <p x-text="flow.trigger"></p>
                          <template x-if="flow.steps && flow.steps.length">
                            <ol class="domain-steps">
                              <template x-for="(s, si) in flow.steps" x-bind:key="si">
                                <li x-text="s"></li>
                              </template>
                            </ol>
                          </template>
                          <div class="domain-meta" x-text="flow.outcome ? `Outcome: ${flow.outcome}` : ''"></div>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="(!step3Data.user_flows || step3Data.user_flows.length === 0) && (!step3Data.system_flows || step3Data.system_flows.length === 0)">
                <div class="empty-state"><p>No flows extracted</p></div>
              </template>
            </div>
          </div>

          <!-- Architecture -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">🏗️ Architecture</h3>
              <span class="badge badge-completed" x-text="(step3Data.architecture_components || []).length + ' components'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.architecture_components && step3Data.architecture_components.length > 0">
                <div class="domain-list">
                  <template x-for="(comp, ci) in step3Data.architecture_components" x-bind:key="ci">
                    <div class="domain-list-item">
                      <strong x-text="comp.component"></strong>
                      <span class="badge badge-in-progress" x-text="comp.type"></span>
                      <p x-text="comp.responsibility"></p>
                      <template x-if="comp.depends_on && comp.depends_on.length">
                        <div class="domain-aliases">
                          <span class="domain-label">Depends on:</span>
                          <template x-for="(dep, di) in comp.depends_on" x-bind:key="di">
                            <span class="badge badge-pending" x-text="dep"></span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.architecture_components || step3Data.architecture_components.length === 0">
                <div class="empty-state"><p>No architecture components extracted</p></div>
              </template>
            </div>
          </div>
        </div>

        <!-- Proceed to Step 4 CTA -->
        <template x-if="phase === 'step3_done'">
          <div class="domain-cta" style="margin-top: var(--space-6);">
            <div class="card" style="background: var(--color-accent-bg); border-color: var(--color-accent);">
              <div class="empty-state">
                <div class="empty-state-icon">📋</div>
                <p>Domain model extracted! Continue to generate detailed specifications across all 11 categories.</p>
                <button class="btn btn-primary" x-on:click="proceedToStep4()" x-bind:disabled="loading">
                  <span x-show="!loading">Continue to Specs</span>
                  <span x-show="loading">Generating Specs…</span>
                </button>
              </div>
            </div>
          </div>
        </template>
      </div>
    </template>

    <!-- Step 4: Spec Tabs (complete) -->
    <template x-if="step4Data && phase === 'complete'">
      <div class="domain-specs" style="margin-top: var(--space-8);">
        <h2 class="section-title">Specifications</h2>

        <div x-data="{ activeSpecTab: 'api' }">
          <div class="tabs-nav">
            {specNames.map((spec) => (
              <button
                class="tab-btn"
                x-on:click={`activeSpecTab = '${spec.id}'`}
                x-bind:class={`{ 'active': activeSpecTab === '${spec.id}' }`}
              >
                {spec.label}
                <template x-if={`step4Data['${spec.id}'] && step4Data['${spec.id}'].length > 0`}>
                  <span class="tab-dot">●</span>
                </template>
              </button>
            ))}
          </div>

          {SPEC_CATEGORIES.map((cat) => (
            <div x-show={`activeSpecTab === '${cat}'`} x-cloak>
              <div class="card spec-card">
                <div class="card-header">
                  <h3 class="card-title">{formatSpecName(cat)}</h3>
                  <span class="badge badge-completed" x-text={`(step4Data['${cat}'] || []).length + ' items'`}></span>
                </div>
                <div class="card-body">
                  <template x-if={`step4Data['${cat}'] && step4Data['${cat}'].length > 0`}>
                    <div class="table-wrapper">
                      <table>
                        <thead>
                          <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Details</th>
                          </tr>
                        </thead>
                        <tbody>
                          <template x-for={`(item, idx) in step4Data['${cat}']`} x-bind:key="idx">
                            <tr>
                              <td x-text="idx + 1"></td>
                              <td>
                                <strong x-text="item.name || item.path || item.route || item.component || ('Item ' + (idx + 1))"></strong>
                              </td>
                              <td>
                                <span x-text="item.description || item.purpose || item.responsibility || item.rule || item.when || JSON.stringify(item).substring(0, 120)"></span>
                              </td>
                            </tr>
                          </template>
                        </tbody>
                      </table>
                    </div>
                  </template>
                  <template x-if={`!step4Data['${cat}'] || step4Data['${cat}'].length === 0`}>
                    <div class="empty-state">
                      <div class="empty-state-icon">📝</div>
                      <p>No {formatSpecName(cat).toLowerCase()} specs generated yet</p>
                    </div>
                  </template>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </template>

    <!-- Success banner when complete -->
    <template x-if="phase === 'complete'">
      <div class="card" style="margin-top: var(--space-6); background: var(--color-success-bg, #0a2e1a); border-color: var(--color-success, #22c55e);">
        <div class="empty-state">
          <div class="empty-state-icon">🎉</div>
          <p>Domain modeling complete! All data has been saved to the Solution Space. <a href="/solution/">View Solution Space →</a></p>
        </div>
      </div>
    </template>

    <!-- Restart button (always visible when not idle) -->
    <template x-if="phase !== 'idle'">
      <div style="margin-top: var(--space-4); text-align: right;">
        <button class="btn btn-secondary btn-sm" x-on:click="restart()" x-bind:disabled="loading">
          ↻ Restart Session
        </button>
      </div>
    </template>
  </div>
</Layout>

<script>
  import { clientPost, getClientApiConfig, SPEC_CATEGORIES, formatSpecName } from '../lib/api';

  document.addEventListener('alpine:init', () => {
    // @ts-ignore
    window.Alpine.data('domainChat', (apiUrl: string) => ({
      messages: [] as Array<{ role: string; text: string; html?: boolean }>,
      input: '',
      loading: false,
      error: '',
      phase: 'idle' as 'idle' | 'step3' | 'extracting3' | 'step3_done' | 'step4' | 'extracting4' | 'complete',
      loadingMessage: 'Thinking…',
      step3Data: null as Record<string, unknown> | null,
      step4Data: null as Record<string, unknown> | null,

      init() {
        this.restoreSession();
      },

      /** Persist session state to localStorage for resilience. */
      saveSession() {
        try {
          const state = {
            phase: this.phase,
            messages: this.messages,
            step3Data: this.step3Data,
            step4Data: this.step4Data,
          };
          localStorage.setItem('bropilot_domain_session', JSON.stringify(state));
        } catch { /* ignore */ }
      },

      /** Restore session from localStorage if available. */
      restoreSession() {
        try {
          const raw = localStorage.getItem('bropilot_domain_session');
          if (raw) {
            const state = JSON.parse(raw);
            if (state && state.phase && state.phase !== 'idle') {
              this.phase = state.phase;
              this.messages = state.messages || [];
              this.step3Data = state.step3Data || null;
              this.step4Data = state.step4Data || null;
            }
          }
        } catch { /* ignore */ }
      },

      /** Clear session from localStorage. */
      clearSession() {
        try {
          localStorage.removeItem('bropilot_domain_session');
        } catch { /* ignore */ }
      },

      async start() {
        this.loading = true;
        this.error = '';
        this.loadingMessage = 'Starting domain modeling…';
        try {
          const json = await clientPost(apiUrl, '/api/domain/start') as {
            ok: boolean;
            data?: { prompt?: string; step?: string };
            error?: string;
          };
          if (json.ok && json.data) {
            this.phase = 'step3';
            if (json.data.prompt) {
              this.messages.push({
                role: 'bot',
                text: json.data.prompt,
              });
            }
            this.saveSession();
          } else {
            throw new Error(json.error || 'Unexpected response from server');
          }
        } catch (err: unknown) {
          const msg = err instanceof Error ? err.message : String(err);
          if (msg.includes('.bropilot')) {
            this.error = msg;
          } else if (msg.includes('Server responded')) {
            this.error = `Could not start domain session. ${msg}`;
          } else {
            this.error = `Could not reach Bropilot server. ${msg}`;
          }
        }
        this.loading = false;
        this.scrollToBottom();
      },

      async submitInput() {
        const text = this.input.trim();
        if (!text) return;

        this.messages.push({ role: 'user', text });
        this.input = '';
        this.loading = true;
        this.loadingMessage = 'Extracting domain model…';
        this.error = '';
        this.scrollToBottom();

        try {
          // First submit the input
          const inputJson = await clientPost(apiUrl, '/api/domain/input', { text }) as {
            ok: boolean;
            error?: string;
          };

          if (!inputJson.ok) {
            throw new Error(inputJson.error || 'Failed to submit input');
          }

          // Then extract
          const extractJson = await clientPost(apiUrl, '/api/domain/extract') as {
            ok: boolean;
            data?: {
              extracted?: Record<string, unknown>;
              status?: string;
              next?: string;
              step4_prompt?: string;
              step4_error?: string;
            };
            error?: string;
          };

          if (extractJson.ok && extractJson.data) {
            const data = extractJson.data;
            this.step3Data = data.extracted || null;

            if (data.status === 'step3_done') {
              this.messages.push({
                role: 'bot',
                text: '✅ Domain model extracted successfully! Review the results below.',
              });

              // Check if step4 auto-started
              if (data.step4_prompt) {
                this.phase = 'step3_done';
              } else if (data.step4_error) {
                this.phase = 'step3_done';
                this.error = `Step 4 auto-start failed: ${data.step4_error}`;
              } else {
                this.phase = 'step3_done';
              }
            } else {
              this.phase = 'step3_done';
            }
            this.saveSession();
          } else {
            throw new Error(extractJson.error || 'Extraction failed');
          }
        } catch (err: unknown) {
          const msg = err instanceof Error ? err.message : String(err);
          if (msg.includes('domain worker not started')) {
            this.error = 'Domain worker not started. Please restart the session.';
          } else {
            this.error = `Extraction failed. ${msg}`;
          }
        }
        this.loading = false;
        this.scrollToBottom();
      },

      async proceedToStep4() {
        this.loading = true;
        this.loadingMessage = 'Generating detailed specifications…';
        this.error = '';
        this.phase = 'extracting4';
        this.saveSession();

        try {
          const json = await clientPost(apiUrl, '/api/domain/extract') as {
            ok: boolean;
            data?: {
              extracted?: Record<string, unknown>;
              status?: string;
            };
            error?: string;
          };

          if (json.ok && json.data) {
            const data = json.data;
            this.step4Data = data.extracted || null;
            this.phase = 'complete';

            this.messages.push({
              role: 'bot',
              text: '✅ All 11 specification categories have been generated! Review the tabs below.',
            });

            this.saveSession();
          } else {
            throw new Error(json.error || 'Step 4 extraction failed');
          }
        } catch (err: unknown) {
          this.phase = 'step3_done';
          this.error = `Specs generation failed. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
        this.scrollToBottom();
      },

      restart() {
        this.messages = [];
        this.input = '';
        this.loading = false;
        this.error = '';
        this.phase = 'idle';
        this.step3Data = null;
        this.step4Data = null;
        this.clearSession();
      },

      scrollToBottom() {
        this.$nextTick(() => {
          const chat = document.getElementById('domain-chat');
          if (chat) chat.scrollTop = chat.scrollHeight;
        });
      },
    }));
  });
</script>

<style>
  .domain-chat {
    max-height: 60vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .chat-message {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .chat-user {
    flex-direction: row-reverse;
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: var(--text-base);
  }

  .chat-bot .chat-avatar {
    background: rgba(99, 102, 241, 0.15);
    color: var(--color-accent);
  }

  .chat-user .chat-avatar {
    background: rgba(34, 197, 94, 0.15);
    color: var(--color-success, #22c55e);
  }

  .chat-bubble {
    max-width: 70%;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }

  .chat-user .chat-bubble {
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.2);
  }

  .chat-role {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .chat-text {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-secondary);
    white-space: pre-wrap;
  }

  .chat-text.typing {
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Domain input */
  .domain-input {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .domain-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .domain-textarea {
    width: 100%;
