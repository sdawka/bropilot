---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { SPEC_CATEGORIES, formatSpecName } from '../lib/api';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

const specNames = SPEC_CATEGORIES.map((cat) => ({
  id: cat,
  label: formatSpecName(cat),
}));
---

<Layout title="Domain Modeling">
  <div class="page-header">
    <h1>Domain Modeling</h1>
    <p class="page-description">Act 2 — Define the big picture domain model and expand into detailed specs</p>
  </div>

  <div class="section" x-data={`domainChat('${apiUrl}')`}>
    <!-- Error banner -->
    <template x-if="error">
      <div class="card" style="background: var(--color-warning-bg, #332b00); border-color: var(--color-warning, #f5a623); margin-bottom: var(--space-4);">
        <div class="empty-state">
          <div class="empty-state-icon">⚠️</div>
          <p>
            <strong>Connect to Bropilot server</strong><br />
            <span x-text="error"></span>
          </p>
        </div>
      </div>
    </template>

    <!-- Chat messages -->
    <div class="domain-chat" id="domain-chat">
      <!-- Idle state: Start button -->
      <template x-if="phase === 'idle'">
        <div class="card">
          <div class="empty-state">
            <div class="empty-state-icon">🌐</div>
            <p>Start domain modeling to define your app's vocabulary, entities, relationships, flows, and architecture.</p>
            <button class="btn btn-primary" x-on:click="start()" x-bind:disabled="loading">
              <span x-show="!loading">Start Domain Modeling</span>
              <span x-show="loading">Starting…</span>
            </button>
          </div>
        </div>
      </template>

      <!-- Chat history -->
      <template x-for="(msg, i) in messages" x-bind:key="i">
        <div class="chat-message" x-bind:class="msg.role === 'bot' ? 'chat-bot' : 'chat-user'">
          <div class="chat-avatar">
            <span x-text="msg.role === 'bot' ? '⬡' : '●'"></span>
          </div>
          <div class="chat-bubble">
            <div class="chat-role" x-text="msg.role === 'bot' ? 'Bropilot' : 'You'"></div>
            <div class="chat-text" x-html="msg.html ? msg.text : undefined" x-text="msg.html ? undefined : msg.text"></div>
          </div>
        </div>
      </template>

      <!-- Loading indicator -->
      <template x-if="loading && phase !== 'idle'">
        <div class="chat-message chat-bot">
          <div class="chat-avatar"><span>⬡</span></div>
          <div class="chat-bubble">
            <div class="chat-role">Bropilot</div>
            <div class="chat-text typing" x-text="loadingMessage"></div>
          </div>
        </div>
      </template>
    </div>

    <!-- Input area for Step 3 -->
    <template x-if="phase === 'step3' && !loading">
      <div class="domain-input">
        <form x-on:submit.prevent="submitInput()" class="domain-form">
          <textarea
            class="domain-textarea"
            placeholder="Describe your domain… What does your application do? What are the main concepts?"
            x-model="input"
            x-bind:disabled="loading"
            x-ref="domainInput"
            rows="4"
          ></textarea>
          <button type="submit" class="btn btn-primary" x-bind:disabled="loading || !input.trim()">
            Submit &amp; Extract
          </button>
        </form>
      </div>
    </template>

    <!-- Domain model cards (Step 3 done) -->
    <template x-if="step3Data && (phase === 'step3_done' || phase === 'step4' || phase === 'extracting4' || phase === 'complete')">
      <div class="domain-results">
        <h2 class="section-title">Domain Model</h2>
        <div class="card-grid">
          <!-- Vocabulary -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">📖 Vocabulary</h3>
              <span class="badge badge-completed" x-text="(step3Data.vocabulary || []).length + ' terms'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.vocabulary && step3Data.vocabulary.length > 0">
                <div class="domain-list">
                  <template x-for="(item, vi) in step3Data.vocabulary" x-bind:key="vi">
                    <div class="domain-list-item">
                      <strong x-text="item.term"></strong>
                      <span class="domain-meta" x-text="item.category ? `[${item.category}]` : ''"></span>
                      <p x-text="item.definition"></p>
                      <template x-if="item.aliases && item.aliases.length">
                        <div class="domain-aliases">
                          <span class="domain-label">Aliases:</span>
                          <template x-for="(alias, ai) in item.aliases" x-bind:key="ai">
                            <span class="badge badge-pending" x-text="alias"></span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.vocabulary || step3Data.vocabulary.length === 0">
                <div class="empty-state"><p>No vocabulary extracted</p></div>
              </template>
            </div>
          </div>

          <!-- Entities -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">📦 Entities</h3>
              <span class="badge badge-completed" x-text="(step3Data.entities || []).length + ' entities'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.entities && step3Data.entities.length > 0">
                <div class="domain-list">
                  <template x-for="(ent, ei) in step3Data.entities" x-bind:key="ei">
                    <div class="domain-list-item">
                      <strong x-text="ent.name"></strong>
                      <p x-text="ent.description"></p>
                      <template x-if="ent.attributes">
                        <div class="domain-attrs">
                          <span class="domain-label">Attributes:</span>
                          <template x-for="(val, key) in ent.attributes" x-bind:key="key">
                            <span class="badge badge-pending"><span x-text="key"></span>: <span x-text="val"></span></span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.entities || step3Data.entities.length === 0">
                <div class="empty-state"><p>No entities extracted</p></div>
              </template>
            </div>
          </div>

          <!-- Relationships -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">🔗 Relationships</h3>
              <span class="badge badge-completed" x-text="(step3Data.relationships || []).length + ' relationships'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.relationships && step3Data.relationships.length > 0">
                <div class="domain-list">
                  <template x-for="(rel, ri) in step3Data.relationships" x-bind:key="ri">
                    <div class="domain-list-item">
                      <strong>
                        <span x-text="rel.source"></span>
                        <span class="domain-arrow">→</span>
                        <span x-text="rel.target"></span>
                      </strong>
                      <span class="badge badge-in-progress" x-text="rel.type"></span>
                      <p x-text="rel.description"></p>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.relationships || step3Data.relationships.length === 0">
                <div class="empty-state"><p>No relationships extracted</p></div>
              </template>
            </div>
          </div>

          <!-- User Flows -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">🔄 Flows</h3>
              <span class="badge badge-completed" x-text="((step3Data.user_flows || []).length + (step3Data.system_flows || []).length) + ' flows'"></span>
            </div>
            <div class="card-body">
              <template x-if="(step3Data.user_flows && step3Data.user_flows.length > 0) || (step3Data.system_flows && step3Data.system_flows.length > 0)">
                <div class="domain-list">
                  <template x-if="step3Data.user_flows && step3Data.user_flows.length > 0">
                    <div>
                      <div class="domain-subheading">User Flows</div>
                      <template x-for="(flow, fi) in step3Data.user_flows" x-bind:key="'uf-'+fi">
                        <div class="domain-list-item">
                          <strong x-text="flow.name"></strong>
                          <span class="domain-meta" x-text="flow.actor ? `Actor: ${flow.actor}` : ''"></span>
                          <p x-text="flow.trigger"></p>
                          <template x-if="flow.steps && flow.steps.length">
                            <ol class="domain-steps">
                              <template x-for="(s, si) in flow.steps" x-bind:key="si">
                                <li x-text="s"></li>
                              </template>
                            </ol>
                          </template>
                          <div class="domain-meta" x-text="flow.outcome ? `Outcome: ${flow.outcome}` : ''"></div>
                        </div>
                      </template>
                    </div>
                  </template>
                  <template x-if="step3Data.system_flows && step3Data.system_flows.length > 0">
                    <div>
                      <div class="domain-subheading">System Flows</div>
                      <template x-for="(flow, fi) in step3Data.system_flows" x-bind:key="'sf-'+fi">
                        <div class="domain-list-item">
                          <strong x-text="flow.name"></strong>
                          <p x-text="flow.trigger"></p>
                          <template x-if="flow.steps && flow.steps.length">
                            <ol class="domain-steps">
                              <template x-for="(s, si) in flow.steps" x-bind:key="si">
                                <li x-text="s"></li>
                              </template>
                            </ol>
                          </template>
                          <div class="domain-meta" x-text="flow.outcome ? `Outcome: ${flow.outcome}` : ''"></div>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="(!step3Data.user_flows || step3Data.user_flows.length === 0) && (!step3Data.system_flows || step3Data.system_flows.length === 0)">
                <div class="empty-state"><p>No flows extracted</p></div>
              </template>
            </div>
          </div>

          <!-- Architecture -->
          <div class="card domain-card">
            <div class="card-header">
              <h3 class="card-title">🏗️ Architecture</h3>
              <span class="badge badge-completed" x-text="(step3Data.architecture_components || []).length + ' components'"></span>
            </div>
            <div class="card-body">
              <template x-if="step3Data.architecture_components && step3Data.architecture_components.length > 0">
                <div class="domain-list">
                  <template x-for="(comp, ci) in step3Data.architecture_components" x-bind:key="ci">
                    <div class="domain-list-item">
                      <strong x-text="comp.component"></strong>
                      <span class="badge badge-in-progress" x-text="comp.type"></span>
                      <p x-text="comp.responsibility"></p>
                      <template x-if="comp.depends_on && comp.depends_on.length">
                        <div class="domain-aliases">
                          <span class="domain-label">Depends on:</span>
                          <template x-for="(dep, di) in comp.depends_on" x-bind:key="di">
                            <span class="badge badge-pending" x-text="dep"></span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <template x-if="!step3Data.architecture_components || step3Data.architecture_components.length === 0">
                <div class="empty-state"><p>No architecture components extracted</p></div>
              </template>
            </div>
          </div>
        </div>

        <!-- Proceed to Step 4 CTA -->
        <template x-if="phase === 'step3_done'">
          <div class="domain-cta" style="margin-top: var(--space-6);">
            <div class="card" style="background: var(--color-accent-bg); border-color: var(--color-accent);">
              <div class="empty-state">
                <div class="empty-state-icon">📋</div>
                <p>Domain model extracted! Continue to generate detailed specifications across all 11 categories.</p>
                <button class="btn btn-primary" x-on:click="proceedToStep4()" x-bind:disabled="loading">
                  <span x-show="!loading">Continue to Specs</span>
                  <span x-show="loading">Generating Specs…</span>
                </button>
              </div>
            </div>
          </div>
        </template>
      </div>
    </template>

    <!-- Step 4: Spec Tabs (complete) -->
    <template x-if="step4Data && phase === 'complete'">
      <div class="domain-specs" style="margin-top: var(--space-8);">
        <h2 class="section-title">Specifications</h2>

        <div x-data="{ activeSpecTab: 'api' }">
          <div class="tabs-nav">
            {specNames.map((spec) => (
              <button
                class="tab-btn"
                x-on:click={`activeSpecTab = '${spec.id}'`}
                x-bind:class={`{ 'active': activeSpecTab === '${spec.id}' }`}
              >
                {spec.label}
                <template x-if={`step4Data['${spec.id}'] && step4Data['${spec.id}'].length > 0`}>
                  <span class="tab-dot">●</span>
                </template>
              </button>
            ))}
          </div>

          {SPEC_CATEGORIES.map((cat) => (
            <div x-show={`activeSpecTab === '${cat}'`} x-cloak>
              <div class="card spec-card">
                <div class="card-header">
                  <h3 class="card-title">{formatSpecName(cat)}</h3>
                  <span class="badge badge-completed" x-text={`(step4Data['${cat}'] || []).length + ' items'`}></span>
                </div>
                <div class="card-body">
                  <template x-if={`step4Data['${cat}'] && step4Data['${cat}'].length > 0`}>
                    <div class="table-wrapper">
                      <table>
                        <thead>
                          <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Details</th>
                          </tr>
                        </thead>
                        <tbody>
                          <template x-for={`(item, idx) in step4Data['${cat}']`} x-bind:key="idx">
                            <tr>
                              <td x-text="idx + 1"></td>
                              <td>
                                <strong x-text="item.name || item.path || item.route || item.component || ('Item ' + (idx + 1))"></strong>
                              </td>
                              <td>
                                <span x-text="item.description || item.purpose || item.responsibility || item.rule || item.when || JSON.stringify(item).substring(0, 120)"></span>
                              </td>
                            </tr>
                          </template>
                        </tbody>
                      </table>
                    </div>
                  </template>
                  <template x-if={`!step4Data['${cat}'] || step4Data['${cat}'].length === 0`}>
                    <div class="empty-state">
                      <div class="empty-state-icon">📝</div>
                      <p>No {formatSpecName(cat).toLowerCase()} specs generated yet</p>
                    </div>
                  </template>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </template>

    <!-- Success banner when complete -->
    <template x-if="phase === 'complete'">
      <div class="card" style="margin-top: var(--space-6); background: var(--color-success-bg, #0a2e1a); border-color: var(--color-success, #22c55e);">
        <div class="empty-state">
          <div class="empty-state-icon">🎉</div>
          <p>Domain modeling complete! All data has been saved to the Solution Space. <a href="/solution/">View Solution Space →</a></p>
        </div>
      </div>
    </template>

    <!-- Restart button (always visible when not idle) -->
    <template x-if="phase !== 'idle'">
      <div style="margin-top: var(--space-4); text-align: right;">
        <button class="btn btn-secondary btn-sm" x-on:click="restart()" x-bind:disabled="loading">
          ↻ Restart Session
        </button>
      </div>
    </template>
  </div>

  <!-- ER Diagram Section -->
  <div class="section" x-data="erSection()" x-on:keydown.escape.window="closePanel()">
    <h2 class="section-title">ER Diagram</h2>

    <!-- Loading -->
    <template x-if="erLoading && !erError">
      <div class="card">
        <div class="empty-state">
          <div class="empty-state-icon">⏳</div>
          <p>Loading domain data…</p>
        </div>
      </div>
    </template>

    <!-- Error -->
    <template x-if="erError">
      <div class="card" style="background: var(--color-warning-bg, #332b00); border-color: var(--color-warning, #f5a623);">
        <div class="empty-state">
          <div class="empty-state-icon">⚠️</div>
          <p><span x-text="erError"></span></p>
        </div>
      </div>
    </template>

    <!-- Empty state -->
    <template x-if="!erLoading && !erError && erIsEmpty">
      <div class="card">
        <div class="empty-state">
          <div class="empty-state-icon">📐</div>
          <p>No domain model yet. Run Act 2 domain modeling above to extract entities and relationships.</p>
        </div>
      </div>
    </template>

    <!-- Diagram -->
    <template x-if="!erLoading && !erError && !erIsEmpty">
      <div class="er-layout">
        <div class="er-wrapper">
          <div class="er-toolbar">
            <span class="er-count" x-text="erEntityCount + ' entities, ' + erRelationshipCount + ' relationships'"></span>
            <div class="er-toolbar-actions">
              <span class="er-hint" x-show="!selectedEntity">Click an entity to explore</span>
              <button class="btn btn-sm" x-on:click="refreshER()">↻ Refresh</button>
            </div>
          </div>
          <div class="er-container" id="er-diagram-container">
            <div id="er-mermaid-output"></div>
          </div>
        </div>

        <!-- Entity Explorer Panel -->
        <template x-if="selectedEntity">
          <div class="entity-panel-backdrop" x-on:click.self="closePanel()">
            <div class="entity-panel" x-on:click.stop>
              <div class="entity-panel-header">
                <div class="entity-panel-title-row">
                  <span class="entity-panel-icon">📦</span>
                  <h2 class="entity-panel-name" x-text="selectedEntity.name"></h2>
                </div>
                <button class="entity-panel-close" x-on:click="closePanel()" aria-label="Close panel">✕</button>
              </div>

              <template x-if="selectedEntity.description">
                <div class="entity-panel-section">
                  <p class="entity-description" x-text="selectedEntity.description"></p>
                </div>
              </template>

              <div class="entity-panel-section">
                <h3 class="entity-section-title">Attributes</h3>
                <template x-if="getEntityAttributes(selectedEntity).length === 0">
                  <p class="entity-empty-note">No attributes defined</p>
                </template>
                <template x-if="getEntityAttributes(selectedEntity).length > 0">
                  <div class="entity-attr-list">
                    <template x-for="attr in getEntityAttributes(selectedEntity)" x-bind:key="attr.name">
                      <div class="entity-attr-row">
                        <span class="entity-attr-name" x-text="attr.name"></span>
                        <span class="entity-attr-type" x-text="attr.type"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>

              <div class="entity-panel-section">
                <h3 class="entity-section-title">Relationships</h3>
                <template x-if="getEntityRelationships(selectedEntity.name).length === 0">
                  <p class="entity-empty-note">No relationships</p>
                </template>
                <template x-if="getEntityRelationships(selectedEntity.name).length > 0">
                  <div class="entity-rel-list">
                    <template x-for="(rel, idx) in getEntityRelationships(selectedEntity.name)" x-bind:key="idx">
                      <div class="entity-rel-row" x-on:click="selectEntityByName(rel.target)">
                        <span class="entity-rel-direction" x-text="rel.direction === 'outgoing' ? '→' : '←'"></span>
                        <span class="entity-rel-type-badge" x-text="rel.type"></span>
                        <span class="entity-rel-target" x-text="rel.target"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
            </div>
          </div>
        </template>
      </div>
    </template>
  </div>
</Layout>

<script>
  import { clientPost, getClientApiConfig, SPEC_CATEGORIES, formatSpecName } from '../lib/api';

  const ER_API_URL = (import.meta as any).env?.PUBLIC_API_URL || 'http://localhost:4000';

  // --- ER Diagram helpers (shared with er.astro) ---
  function sanitizeName(name: string): string {
    return name.replace(/[^a-zA-Z0-9_]/g, '_').replace(/^_+|_+$/g, '') || 'unnamed';
  }
  function sanitizeType(type: string): string {
    let t = type.replace(/\(.*\)/, '');
    t = t.replace(/[^a-zA-Z0-9_]/g, '_').replace(/^_+|_+$/g, '');
    return t || 'string';
  }
  function normalizeAttributes(attrs?: Record<string, string> | Array<{ name: string; type: string }>): Array<{ name: string; type: string }> {
    if (!attrs) return [];
    if (Array.isArray(attrs)) return attrs.map((a) => ({ name: a.name || 'unknown', type: a.type || 'string' }));
    return Object.entries(attrs).map(([key, val]) => ({ name: key, type: typeof val === 'string' ? val : 'string' }));
  }
  function cardinalityMarkers(type: string): { left: string; right: string } {
    switch (type?.toLowerCase()) {
      case 'has_one': return { left: '||', right: '||' };
      case 'has_many': return { left: '||', right: 'o{' };
      case 'belongs_to': return { left: '}o', right: '||' };
      case 'many_to_many': return { left: '}o', right: 'o{' };
      case 'produces': return { left: '||', right: 'o{' };
      case 'feeds_back': return { left: '}o', right: '||' };
      case 'validates_gate': return { left: '||', right: '||' };
      default: return { left: '||', right: 'o{' };
    }
  }
  function escapeLabel(text: string): string {
    return text.replace(/"/g, "'").replace(/\n/g, ' ').substring(0, 60);
  }

  document.addEventListener('alpine:init', () => {
    // @ts-ignore - ER Section
    window.Alpine.data('erSection', () => ({
      erLoading: true,
      erError: '',
      erIsEmpty: false,
      entities: [] as Array<any>,
      relationships: [] as Array<any>,
      erEntityCount: 0,
      erRelationshipCount: 0,
      selectedEntity: null as any,

      async init() {
        await this.loadERData();
      },

      async loadERData() {
        this.erLoading = true;
        this.erError = '';
        this.erIsEmpty = false;
        try {
          const cfg = getClientApiConfig(ER_API_URL);
          const headers: Record<string, string> = { 'Content-Type': 'application/json' };
          if (cfg.token) headers['Authorization'] = `Bearer ${cfg.token}`;

          const domainRes = await fetch(`${cfg.url}/api/map/solution/domain`, { headers });
          if (!domainRes.ok) {
            if (domainRes.status === 404) { this.erIsEmpty = true; this.erLoading = false; return; }
            throw new Error(`Server responded ${domainRes.status}`);
          }
          const json = await domainRes.json();
          if (!json.ok) {
            if (json.error?.includes('not found')) { this.erIsEmpty = true; this.erLoading = false; return; }
            throw new Error(json.error || 'Unknown error');
          }
          const data = json.data || {};
          const entitiesData = data.entities?.entities || data.entities || [];
          const relationshipsData = data.relationships?.relationships || data.relationships || [];
          this.entities = Array.isArray(entitiesData) ? entitiesData : [];
          this.relationships = Array.isArray(relationshipsData) ? relationshipsData : [];
          this.erEntityCount = this.entities.length;
          this.erRelationshipCount = this.relationships.length;

          if (this.entities.length === 0) { this.erIsEmpty = true; this.erLoading = false; return; }
          this.erLoading = false;
          await this.$nextTick();
          await this.renderDiagram();
        } catch (err: unknown) {
          const error = err as Error;
          if (error.message?.includes('Failed to fetch') || error.message?.includes('NetworkError')) {
            this.erError = 'Could not reach the API. Make sure the Bropilot server is running.';
          } else {
            this.erError = error.message || 'Failed to load domain data';
          }
          this.erLoading = false;
        }
      },

      async refreshER() { this.selectedEntity = null; await this.loadERData(); },
      selectEntityByName(name: string) {
        const entity = this.entities.find((e: any) => e.name === name || sanitizeName(e.name) === sanitizeName(name));
        if (entity) this.selectedEntity = entity;
      },
      closePanel() { this.selectedEntity = null; },
      getEntityAttributes(entity: any): Array<{ name: string; type: string }> {
        return normalizeAttributes(entity.attributes);
      },
      getEntityRelationships(entityName: string): Array<any> {
        const results: Array<any> = [];
        for (const rel of this.relationships) {
          if (rel.source === entityName) results.push({ direction: 'outgoing', type: rel.type, target: rel.target });
          if (rel.target === entityName && rel.source !== entityName) results.push({ direction: 'incoming', type: rel.type, target: rel.source });
        }
        return results;
      },

      buildMermaidDefinition(): string {
        const lines: string[] = ['erDiagram'];
        for (const entity of this.entities) {
          const safeName = sanitizeName(entity.name);
          const attrs = normalizeAttributes(entity.attributes);
          if (attrs.length > 0) {
            lines.push(`    ${safeName} {`);
            for (const attr of attrs) lines.push(`        ${sanitizeType(attr.type)} ${sanitizeName(attr.name)}`);
            lines.push('    }');
          } else {
            lines.push(`    ${safeName} {`);
            lines.push('    }');
          }
        }
        const entityNames = new Set(this.entities.map((e: any) => sanitizeName(e.name)));
        for (const rel of this.relationships) {
          const source = sanitizeName(rel.source);
          const target = sanitizeName(rel.target);
          if (!entityNames.has(source) || !entityNames.has(target)) continue;
          const { left, right } = cardinalityMarkers(rel.type);
          const label = rel.description ? `"${escapeLabel(rel.description)}"` : `"${rel.type}"`;
          lines.push(`    ${source} ${left}--${right} ${target} : ${label}`);
        }
        return lines.join('\n');
      },

      async renderDiagram() {
        const container = document.getElementById('er-mermaid-output');
        if (!container) return;
        const definition = this.buildMermaidDefinition();
        try {
          const { default: mermaid } = await import('mermaid');
          mermaid.initialize({ startOnLoad: false, theme: 'base', themeVariables: { primaryColor: '#eef2ff', primaryBorderColor: '#6366f1', primaryTextColor: '#1a1a2e', lineColor: '#6366f1' }, er: { useMaxWidth: true, layoutDirection: 'TB' }, securityLevel: 'loose' });
          const id = 'er-domain-' + Date.now();
          const { svg } = await mermaid.render(id, definition);
          container.innerHTML = svg;
          this.attachEntityClickHandlers(container);
        } catch (renderErr: unknown) {
          const error = renderErr as Error;
          container.innerHTML = `<div class="empty-state"><div class="empty-state-icon">⚠️</div><p>Failed to render diagram. ${error.message || 'Unknown rendering error'}</p></div>`;
        }
      },

      attachEntityClickHandlers(container: HTMLElement) {
        const self = this;
        const entityMap = new Map<string, any>();
        for (const entity of this.entities) { entityMap.set(sanitizeName(entity.name), entity); entityMap.set(entity.name, entity); }
        const svgEl = container.querySelector('svg');
        if (!svgEl) return;
        const gElements = svgEl.querySelectorAll('g[id]');
        for (const g of gElements) {
          const gId = g.getAttribute('id') || '';
          const entityMatch = gId.match(/-entity-([A-Za-z0-9_]+)-\d+$/);
          if (entityMatch) {
            const entity = entityMap.get(entityMatch[1]);
            if (entity) { (g as SVGGElement).style.cursor = 'pointer'; g.addEventListener('click', (e: Event) => { e.stopPropagation(); self.selectedEntity = entity; }); }
          }
        }
        const textElements = svgEl.querySelectorAll('text');
        for (const text of textElements) {
          const textContent = (text.textContent || '').trim();
          const entity = entityMap.get(textContent);
          if (entity) {
            let parentG: Element | null = text.parentElement;
            while (parentG && parentG !== svgEl) {
              const rect = parentG.querySelector('rect');
              if (rect && parentG.tagName === 'g') {
                (parentG as SVGGElement).style.cursor = 'pointer';
                if (!(parentG as HTMLElement).dataset.entityBound) {
                  (parentG as HTMLElement).dataset.entityBound = 'true';
                  parentG.addEventListener('click', (e: Event) => { e.stopPropagation(); self.selectedEntity = entity; });
                }
                break;
              }
              parentG = parentG.parentElement;
            }
          }
        }
      },
    }));

    // @ts-ignore
    window.Alpine.data('domainChat', (apiUrl: string) => ({
      messages: [] as Array<{ role: string; text: string; html?: boolean }>,
      input: '',
      loading: false,
      error: '',
      phase: 'idle' as 'idle' | 'step3' | 'extracting3' | 'step3_done' | 'step4' | 'extracting4' | 'complete',
      loadingMessage: 'Thinking…',
      step3Data: null as Record<string, unknown> | null,
      step4Data: null as Record<string, unknown> | null,

      init() {
        this.restoreSession();
      },

      /** Persist session state to localStorage for resilience. */
      saveSession() {
        try {
          const state = {
            phase: this.phase,
            messages: this.messages,
            step3Data: this.step3Data,
            step4Data: this.step4Data,
          };
          localStorage.setItem('bropilot_domain_session', JSON.stringify(state));
        } catch { /* ignore */ }
      },

      /** Restore session from localStorage if available. */
      restoreSession() {
        try {
          const raw = localStorage.getItem('bropilot_domain_session');
          if (raw) {
            const state = JSON.parse(raw);
            if (state && state.phase && state.phase !== 'idle') {
              this.phase = state.phase;
              this.messages = state.messages || [];
              this.step3Data = state.step3Data || null;
              this.step4Data = state.step4Data || null;
            }
          }
        } catch { /* ignore */ }
      },

      /** Clear session from localStorage. */
      clearSession() {
        try {
          localStorage.removeItem('bropilot_domain_session');
        } catch { /* ignore */ }
      },

      async start() {
        this.loading = true;
        this.error = '';
        this.loadingMessage = 'Starting domain modeling…';
        try {
          const json = await clientPost(apiUrl, '/api/domain/start') as {
            ok: boolean;
            data?: { prompt?: string; step?: string };
            error?: string;
          };
          if (json.ok && json.data) {
            this.phase = 'step3';
            if (json.data.prompt) {
              this.messages.push({
                role: 'bot',
                text: json.data.prompt,
              });
            }
            this.saveSession();
          } else {
            throw new Error(json.error || 'Unexpected response from server');
          }
        } catch (err: unknown) {
          const msg = err instanceof Error ? err.message : String(err);
          if (msg.includes('.bropilot')) {
            this.error = msg;
          } else if (msg.includes('Server responded')) {
            this.error = `Could not start domain session. ${msg}`;
          } else {
            this.error = `Could not reach Bropilot server. ${msg}`;
          }
        }
        this.loading = false;
        this.scrollToBottom();
      },

      async submitInput() {
        const text = this.input.trim();
        if (!text) return;

        this.messages.push({ role: 'user', text });
        this.input = '';
        this.loading = true;
        this.loadingMessage = 'Extracting domain model…';
        this.error = '';
        this.scrollToBottom();

        try {
          // First submit the input
          const inputJson = await clientPost(apiUrl, '/api/domain/input', { text }) as {
            ok: boolean;
            error?: string;
          };

          if (!inputJson.ok) {
            throw new Error(inputJson.error || 'Failed to submit input');
          }

          // Then extract
          const extractJson = await clientPost(apiUrl, '/api/domain/extract') as {
            ok: boolean;
            data?: {
              extracted?: Record<string, unknown>;
              status?: string;
              next?: string;
              step4_prompt?: string;
              step4_error?: string;
            };
            error?: string;
          };

          if (extractJson.ok && extractJson.data) {
            const data = extractJson.data;
            this.step3Data = data.extracted || null;

            if (data.status === 'step3_done') {
              this.messages.push({
                role: 'bot',
                text: '✅ Domain model extracted successfully! Review the results below.',
              });

              // Check if step4 auto-started
              if (data.step4_prompt) {
                this.phase = 'step3_done';
              } else if (data.step4_error) {
                this.phase = 'step3_done';
                this.error = `Step 4 auto-start failed: ${data.step4_error}`;
              } else {
                this.phase = 'step3_done';
              }
            } else {
              this.phase = 'step3_done';
            }
            this.saveSession();
          } else {
            throw new Error(extractJson.error || 'Extraction failed');
          }
        } catch (err: unknown) {
          const msg = err instanceof Error ? err.message : String(err);
          if (msg.includes('domain worker not started')) {
            this.error = 'Domain worker not started. Please restart the session.';
          } else {
            this.error = `Extraction failed. ${msg}`;
          }
        }
        this.loading = false;
        this.scrollToBottom();
      },

      async proceedToStep4() {
        this.loading = true;
        this.loadingMessage = 'Generating detailed specifications…';
        this.error = '';
        this.phase = 'extracting4';
        this.saveSession();

        try {
          const json = await clientPost(apiUrl, '/api/domain/extract') as {
            ok: boolean;
            data?: {
              extracted?: Record<string, unknown>;
              status?: string;
            };
            error?: string;
          };

          if (json.ok && json.data) {
            const data = json.data;
            this.step4Data = data.extracted || null;
            this.phase = 'complete';

            this.messages.push({
              role: 'bot',
              text: '✅ All 11 specification categories have been generated! Review the tabs below.',
            });

            this.saveSession();
          } else {
            throw new Error(json.error || 'Step 4 extraction failed');
          }
        } catch (err: unknown) {
          this.phase = 'step3_done';
          this.error = `Specs generation failed. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
        this.scrollToBottom();
      },

      restart() {
        this.messages = [];
        this.input = '';
        this.loading = false;
        this.error = '';
        this.phase = 'idle';
        this.step3Data = null;
        this.step4Data = null;
        this.clearSession();
      },

      scrollToBottom() {
        this.$nextTick(() => {
          const chat = document.getElementById('domain-chat');
          if (chat) chat.scrollTop = chat.scrollHeight;
        });
      },
    }));
  });
</script>

