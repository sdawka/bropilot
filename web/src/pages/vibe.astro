---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
// Note: client-side Alpine code reads the actual URL + token from localStorage (see vibeChat data below).
---

<Layout title="Vibe">
  <div class="page-header">
    <h1>Vibe Session</h1>
    <p class="page-description">Have a conversation with Bropilot to capture project vibes</p>
  </div>

  <div class="section" x-data={`vibeChat('${apiUrl}')`}>
    <!-- Status banner -->
    <template x-if="error">
      <div class="card" style="background: var(--color-warning-bg, #332b00); border-color: var(--color-warning, #f5a623); margin-bottom: var(--space-4);">
        <div class="empty-state">
          <div class="empty-state-icon">⚠️</div>
          <p>
            <strong>Connect to Bropilot server</strong><br />
            <span x-text="error"></span>
          </p>
        </div>
      </div>
    </template>

    <!-- Chat messages -->
    <div class="vibe-chat" id="vibe-chat">
      <template x-if="messages.length === 0 && !started">
        <div class="card">
          <div class="empty-state">
            <div class="empty-state-icon">💬</div>
            <p>Start a vibe session to have a conversation about your project. Bropilot will ask questions to understand your vision.</p>
            <button class="btn btn-primary" x-on:click="start()" x-bind:disabled="loading">
              <span x-show="!loading">Start Vibe Session</span>
              <span x-show="loading">Starting…</span>
            </button>
          </div>
        </div>
      </template>

      <template x-for="(msg, i) in messages" x-bind:key="i">
        <div class="chat-message" x-bind:class="msg.role === 'bot' ? 'chat-bot' : 'chat-user'">
          <div class="chat-avatar">
            <span x-text="msg.role === 'bot' ? '⬡' : '●'"></span>
          </div>
          <div class="chat-bubble">
            <div class="chat-role" x-text="msg.role === 'bot' ? 'Bropilot' : 'You'"></div>
            <div class="chat-text" x-text="msg.text"></div>
          </div>
        </div>
      </template>

      <template x-if="loading && started">
        <div class="chat-message chat-bot">
          <div class="chat-avatar"><span>⬡</span></div>
          <div class="chat-bubble">
            <div class="chat-role">Bropilot</div>
            <div class="chat-text typing">Thinking…</div>
          </div>
        </div>
      </template>
    </div>

    <!-- Input area -->
    <template x-if="started && !done">
      <div class="vibe-input">
        <form x-on:submit.prevent="send()" class="vibe-form">
          <input
            type="text"
            class="search-input"
            placeholder="Type your response…"
            x-model="input"
            x-bind:disabled="loading"
            x-ref="vibeInput"
          />
          <button type="submit" class="btn btn-primary" x-bind:disabled="loading || !input.trim()">
            Send
          </button>
        </form>
      </div>
    </template>

    <!-- Extract button when done -->
    <template x-if="done && !extracted">
      <div class="vibe-actions" style="margin-top: var(--space-4);">
        <div class="card">
          <div class="empty-state">
            <div class="empty-state-icon">✨</div>
            <p>Vibe session complete! Extract the captured vibes to save them to your project.</p>
            <button class="btn btn-primary" x-on:click="extract()" x-bind:disabled="loading">
              <span x-show="!loading">Extract Vibes</span>
              <span x-show="loading">Extracting…</span>
            </button>
          </div>
        </div>
      </div>
    </template>

    <template x-if="extracted">
      <div class="card" style="margin-top: var(--space-4); background: var(--color-success-bg, #0a2e1a); border-color: var(--color-success, #22c55e);">
        <div class="empty-state">
          <div class="empty-state-icon">🎉</div>
          <p>Vibes extracted and saved! Check the Problem Space to see the results.</p>
        </div>
      </div>
    </template>
  </div>
</Layout>

<script>
  import { getClientApiConfig, clientPost } from '../lib/api';

  document.addEventListener('alpine:init', () => {
    // @ts-ignore
    window.Alpine.data('vibeChat', (apiUrl: string) => ({
      messages: [] as Array<{ role: string; text: string }>,
      input: '',
      loading: false,
      started: false,
      done: false,
      extracted: false,
      error: '',

      async start() {
        this.loading = true;
        this.error = '';
        try {
          const json = await clientPost(apiUrl, '/api/vibe/start') as { ok: boolean; data?: { question?: string; message?: string } };
          if (json.ok && json.data) {
            this.started = true;
            if (json.data.question || json.data.message) {
              this.messages.push({
                role: 'bot',
                text: json.data.question || json.data.message || '',
              });
            }
          } else {
            throw new Error('Unexpected response');
          }
        } catch (err: unknown) {
          this.error = `Could not start vibe session. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
        this.scrollToBottom();
      },

      async send() {
        const text = this.input.trim();
        if (!text) return;

        this.messages.push({ role: 'user', text });
        this.input = '';
        this.loading = true;
        this.error = '';
        this.scrollToBottom();

        try {
          const json = await clientPost(apiUrl, '/api/vibe/input', { text }) as { ok: boolean; data?: { done?: boolean; question?: string; message?: string } };
          if (json.ok && json.data) {
            if (json.data.done) {
              this.done = true;
              if (json.data.message) {
                this.messages.push({ role: 'bot', text: json.data.message });
              }
            } else if (json.data.question || json.data.message) {
              this.messages.push({
                role: 'bot',
                text: json.data.question || json.data.message || '',
              });
            }
          }
        } catch (err: unknown) {
          this.error = `Failed to send message. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
        this.scrollToBottom();

        // Re-focus input after sending
        this.$nextTick(() => {
          if (this.$refs.vibeInput) {
            (this.$refs.vibeInput as HTMLInputElement).focus();
          }
        });
      },

      async extract() {
        this.loading = true;
        this.error = '';
        try {
          const json = await clientPost(apiUrl, '/api/vibe/extract') as { ok: boolean };
          if (json.ok) {
            this.extracted = true;
          } else {
            throw new Error('Extraction failed');
          }
        } catch (err: unknown) {
          this.error = `Failed to extract vibes. ${err instanceof Error ? err.message : String(err)}`;
        }
        this.loading = false;
      },

      scrollToBottom() {
        this.$nextTick(() => {
          const chat = document.getElementById('vibe-chat');
          if (chat) chat.scrollTop = chat.scrollHeight;
        });
      },
    }));
  });
</script>

<style>
  .vibe-chat {
    max-height: 60vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .chat-message {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .chat-user {
    flex-direction: row-reverse;
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: var(--text-base);
  }

  .chat-bot .chat-avatar {
    background: rgba(99, 102, 241, 0.15);
    color: var(--color-accent);
  }

  .chat-user .chat-avatar {
    background: rgba(34, 197, 94, 0.15);
    color: var(--color-success, #22c55e);
  }

  .chat-bubble {
    max-width: 70%;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }

  .chat-user .chat-bubble {
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.2);
  }

  .chat-role {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .chat-text {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .chat-text.typing {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .vibe-input {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .vibe-form {
    display: flex;
    gap: var(--space-3);
  }

  .vibe-form .search-input {
    flex: 1;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 600;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .btn-primary:hover:not(:disabled) {
    filter: brightness(1.1);
  }
</style>
